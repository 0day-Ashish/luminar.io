# Luminar Oracle Server - Environment Variables
# Copy this file to .env and fill in the values.

# Required: HMAC secret key for oracle attestation signing
ORACLE_SECRET_KEY="your-secret-key-here"

# Required: Multi-Oracle ECDSA Secp256k1 private keys (hex, with 0x prefix)
# These keys are used for the 2-of-3 threshold consensus signatures
# verified inside the Noir ZK circuit.
ORACLE_1_PRIVATE_KEY="0x..."
ORACLE_2_PRIVATE_KEY="0x..."
ORACLE_3_PRIVATE_KEY="0x..."

# Optional: Surepass API token for live PAN card verification
# Without this, PAN cards are accepted via format validation only.
SUREPASS_TOKEN="your-surepass-token-here"
SUREPASS_BASE_URL="https://sandbox.surepass.app"
